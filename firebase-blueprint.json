{
  "entities": {
    "Review": {
      "title": "Internal Place Review",
      "description": "User generated review for a specific place within the app.",
      "type": "object",
      "properties": {
        "placeId": { "type": "string", "description": "The Google Maps Place ID" },
        "userId": { "type": "string", "description": "The Firebase Auth UID of the reviewer" },
        "userName": { "type": "string", "description": "The display name of the reviewer" },
        "userPhoto": { "type": "string", "description": "The profile photo URL of the reviewer" },
        "rating": { "type": "number", "description": "Rating from 1 to 5" },
        "comment": { "type": "string", "description": "Textual review content" },
        "photoBase64": { "type": "string", "description": "Optional attached photo in base64 format" },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the review was created" }
      },
      "required": ["placeId", "userId", "rating", "createdAt"]
    },
    "Favorite": {
      "title": "User Favorite Place",
      "description": "A place saved by a user for quick access.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "The Firebase Auth UID of the user" },
        "placeId": { "type": "string", "description": "The Google Maps Place ID" },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the favorite was added" }
      },
      "required": ["userId", "placeId", "createdAt"]
    },
    "Visit": {
      "title": "User Visit Record",
      "description": "Track places a user has looked at to remind them to rate later.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "The Firebase Auth UID of the user" },
        "placeId": { "type": "string", "description": "The Google Maps Place ID" },
        "placeName": { "type": "string", "description": "Name of the place visited" },
        "timestamp": { "type": "string", "format": "date-time", "description": "When the visit occurred" },
        "rated": { "type": "boolean", "description": "Whether this visit has been rated" }
      },
      "required": ["userId", "placeId", "timestamp"]
    },
    "CoveragePost": {
      "title": "Abu Abdullah Coverage Post",
      "description": "A blog-style post with multiple media items and a report.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "authorId": { "type": "string" },
        "authorName": { "type": "string" },
        "mediaCount": { "type": "number" }
      },
      "required": ["title", "description", "createdAt", "authorId"]
    },
    "CoverageMedia": {
      "title": "Coverage Media",
      "description": "A single media item (image or video) for a post, possibly chunked.",
      "type": "object",
      "properties": {
        "type": { "type": "string", "enum": ["image", "video"] },
        "order": { "type": "number" },
        "totalChunks": { "type": "number" },
        "isChunked": { "type": "boolean" },
        "data": { "type": "string", "description": "Base64 data or first chunk" }
      }
    },
    "MediaChunk": {
      "title": "Media Chunk",
      "description": "A component of a larger media file.",
      "type": "object",
      "properties": {
        "data": { "type": "string" },
        "index": { "type": "number" }
      }
    },
    "AppSettings": {
      "title": "Global App Settings",
      "description": "Global configuration like the coverage intro text.",
      "type": "object",
      "properties": {
        "coverageIntro": { "type": "string" }
      }
    },
    "Place": {
      "title": "Cloud Place",
      "description": "A place stored in Firestore to override or augment Google Maps data.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "vicinity": { "type": "string" },
        "rating": { "type": "number" },
        "user_ratings_total": { "type": "number" },
        "types": { "type": "array", "items": { "type": "string" } },
        "photos": { "type": "array", "items": { "type": "object" } },
        "geometry": { "type": "object" }
      }
    },
    "Rating": {
      "title": "Consolidated Rating",
      "description": "Consolidated rating for a place",
      "type": "object",
      "properties": {
        "rating": { "type": "number" },
        "count": { "type": "number" }
      }
    },
    "MenuItem": {
      "title": "Menu Item",
      "description": "A food or drink item in a restaurant's menu.",
      "type": "object",
      "properties": {
        "placeId": { "type": "string" },
        "name": { "type": "string" },
        "price": { "type": "number" },
        "imageUrl": { "type": "string" },
        "description": { "type": "string" }
      },
      "required": ["placeId", "name", "price"]
    },
    "Order": {
      "title": "Customer Order",
      "description": "A pick-up order placed by a user.",
      "type": "object",
      "properties": {
        "placeId": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "items": { "type": "array", "items": { "type": "object" } },
        "total": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "confirmed", "ready", "picked_up", "cancelled"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["placeId", "userId", "items", "total", "status", "createdAt"]
    },
    "RestaurantSettings": {
      "title": "Restaurant Specific Settings",
      "description": "Settings for a specific restaurant/place, like its WhatsApp number.",
      "type": "object",
      "properties": {
        "placeId": { "type": "string" },
        "whatsappNumber": { "type": "string" },
        "ownerId": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["placeId", "whatsappNumber"]
    },
    "UserProfile": {
      "title": "User Profile",
      "description": "Extended information about a user, including their role.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "role": { "type": "string", "enum": ["customer", "vendor", "admin"] },
        "ownedPlaceId": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "role"]
    }
  },
  "firestore": {
    "/userProfiles/{uid}": {
      "schema": "UserProfile",
      "description": "Profiles for users differentiating roles"
    },
    "/restaurantSettings/{placeId}": {
      "schema": "RestaurantSettings",
      "description": "Configuration for a specific restaurant/cafe"
    },
    "/menus/{menuId}": {
      "schema": "MenuItem",
      "description": "Food items for restaurants"
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Customer pick-up orders"
    },
    "/coveragePosts/{postId}/media/{mediaId}": {
      "schema": "CoverageMedia",
      "description": "Images and videos attached to a post"
    },
    "/coveragePosts/{postId}/media/{mediaId}/chunks/{chunkId}": {
      "schema": "MediaChunk",
      "description": "Chunks of large media files"
    },
    "/places/{placeId}": {
      "schema": "Place",
      "description": " Abu Abdullah's curated places"
    },
    "/ratings/{placeId}": {
      "schema": "Rating",
      "description": "Aggregated ratings for places"
    },
    "/reviews/{reviewId}": {
      "schema": "Review",
      "description": "Global collection of all user reviews"
    },
    "/favorites/{favoriteId}": {
      "schema": "Favorite",
      "description": "User specific favorite places"
    },
    "/visits/{visitId}": {
      "schema": "Visit",
      "description": "Track user visits for rating reminders"
    },
    "/coveragePosts/{postId}": {
      "schema": "CoveragePost",
      "description": "Abu Abdullah's special coverages"
    },
    "/settings/{settingId}": {
      "schema": "AppSettings",
      "description": "Global app settings"
    }
  }
}
